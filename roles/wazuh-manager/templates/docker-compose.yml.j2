version: '3.8'

services:
  wazuh-manager:
    image: wazuh/wazuh-manager:4.14.0
    container_name: wazuh-manager
    restart: always
    ports:
      - "1514:1514/udp"
      - "1514:1514/tcp"
      - "1515:1515/tcp"
      - "55000:55000/tcp"
    environment:
      - WAZUH_CLUSTER_ENABLED=no
    volumes:
      - wazuh_api_configuration:/var/ossec/api/configuration
      - wazuh_etc:/var/ossec/etc
      - wazuh_logs:/var/ossec/logs
      - wazuh_queue:/var/ossec/queue

  wazuh-dashboard:
    image: wazuh/wazuh-dashboard:4.14.0
    container_name: wazuh-dashboard
    restart: always
    ports:
      - "443:8443/tcp"
    environment:
      - WAZUH_MANAGER_URL=https://wazuh-manager:55000
      - INDEXER_URL=https://wazuh-manager:55000
      - INDEXER_SSL_VERIFICATION_MODE=none
      - API_SSL_VERIFICATION_MODE=none
    volumes:
      - ./opensearch_dashboards.yml:/usr/share/wazuh-dashboard/config/opensearch_dashboards.yml
    depends_on:
      - wazuh-manager

volumes:
  wazuh_api_configuration:
  wazuh_etc:
  wazuh_logs:
  wazuh_queue:
