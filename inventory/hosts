[manager_group]
manager ansible_host=192.168.100.20

[vault_group]
vault ansible_host=192.168.100.30

[agents_group]
agent-01 ansible_host=192.168.100.41
agent-02 ansible_host=192.168.100.42

[all:vars]
ansible_user=ansible
ansible_ssh_private_key_file=~/.ssh/id_ed25519
ansible_python_interpreter=/usr/bin/python3
host_number={{ inventory_hostname | regex_replace('^.*(\d+)$', '\1') | default('10') }}
